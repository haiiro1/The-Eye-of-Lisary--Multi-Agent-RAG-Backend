# --- API KEYS ---
# Obtenla en https://fireworks.ai/
FIREWORKS_API_KEY=tu_api_key_aqui

# Opcional: Para escalabilidad o agentes específicos de otros proveedores
GOOGLE_API_KEY=tu_api_key_aqui
OPENAI_API_KEY=tu_api_key_aqui

# Obtenla en https://tavily.com/
TAVILY_API_KEY=tu_api_key_aqui

HF_TOKEN=hf_tu_token_aqui
# --- LANGFUSE (MONITOREO V2+) ---
# Consigue tus credenciales en https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# --- CONFIGURACIÓN DE RUTAS ---
# Rutas relativas a la raíz del proyecto para persistencia
CHROMA_PATH=data/vector_store
MANUALS_PATH=data/manuales
DB_PATH=data/chat_history.db

# --- MODELOS ---
# Modelos sugeridos de Qwen 2.5 en Fireworks
ROUTING_MODEL=accounts/fireworks/models/qwen2p5-72b-instruct
REASONING_MODEL=accounts/fireworks/models/qwen2p5-72b-instruct